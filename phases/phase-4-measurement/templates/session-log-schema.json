{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Session Log",
  "description": "에이전트 개발 세션의 메트릭 기록 스키마",
  "type": "object",
  "required": ["session_id", "date", "project", "workflow_tier", "files_changed", "tokens"],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "세션 고유 식별자 (날짜-작업명 형식 권장)",
      "pattern": "^[a-z0-9-]+$",
      "examples": ["2026-03-15-auth-jwt"]
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "세션 날짜 (ISO 8601)"
    },
    "project": {
      "type": "string",
      "description": "프로젝트 이름"
    },
    "workflow_tier": {
      "type": "string",
      "enum": ["micro", "standard", "full"],
      "description": "적용된 워크플로우 단계"
    },
    "domain_profile": {
      "type": "string",
      "description": "적용된 도메인 프로필 이름 (없으면 빈 문자열)",
      "default": ""
    },
    "milestones": {
      "type": "integer",
      "minimum": 0,
      "description": "총 마일스톤 수 (Micro는 0)"
    },
    "files_changed": {
      "type": "integer",
      "minimum": 0,
      "description": "변경된 파일 수"
    },
    "qr_iterations": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "description": "마일스톤별 QR 반복 횟수 (Micro는 빈 배열)"
    },
    "rework_count": {
      "type": "integer",
      "minimum": 0,
      "description": "같은 파일을 2회 이상 수정한 횟수"
    },
    "tokens": {
      "type": "object",
      "required": ["total"],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0,
          "description": "총 토큰 소비"
        },
        "input": {
          "type": "integer",
          "minimum": 0,
          "description": "입력 토큰"
        },
        "output": {
          "type": "integer",
          "minimum": 0,
          "description": "출력 토큰"
        },
        "cache_read": {
          "type": "integer",
          "minimum": 0,
          "description": "캐시 읽기 토큰"
        },
        "cache_create": {
          "type": "integer",
          "minimum": 0,
          "description": "캐시 생성 토큰"
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0,
          "description": "세션 총 비용 (USD). token-monitor에서 자동 산출"
        }
      }
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 0,
      "description": "세션 소요 시간 (분)"
    },
    "notes": {
      "type": "string",
      "description": "특이사항, QR 실패 원인 등 자유 기록"
    }
  }
}
